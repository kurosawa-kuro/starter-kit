NODE_ENV=dev
LOG_LEVEL=debug
PORT=8080
CORS_ORIGIN=http://localhost:3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dev_db
DB_USER=dev_user
DB_PASSWORD=dev_password
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=dev_jwt_secret
JWT_EXPIRES_IN=24h
API_VERSION=v1
API_PREFIX=/api

# ステージングではPoCログイン許可する場合も
ALLOW_SIMPLE_LOGIN=false